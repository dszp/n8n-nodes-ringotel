{
	"name": "n8n-nodes-ringotel",
	"version": "0.0.1",
	"description": "n8n community node for the Ringotel Admin and Messaging APIs",
	"license": "MIT",
	"homepage": "https://github.com/dszp/n8n-nodes-ringotel",
    "author": {
        "name": "David Szpunar",
        "email": "davidszp@gmail.com",
        "url": "https://david.szpunar.com"
    },
	"repository": {
		"type": "git",
		"url": "https://github.com/dszp/n8n-nodes-ringotel.git"
	},
	"keywords": [
		"n8n-community-node-package"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/RingotelAdminApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/RingotelAdmin/RingotelAdmin.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
