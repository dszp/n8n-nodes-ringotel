      "name": "Webhook Notifications",
      "item": [
        {
          "name": "Text Message",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n\t\"method\":\"message\",\n\t\"params\":{\n\t\t\"to\": \"{{sender_phone}}\",\n\t\t\"from\": \"{{user_phone}}\",\n\t\t\"orgid\": \"{{orgid}}\",\n\t\t\"userid\": \"{{userid}}\",\n\t\t\"messageid\": \"{{messageid}}\",\n\t    \"sessionid\": \"{{sessionid}}\",\n\t\t\"content\":\"Hello World!\",\n\t\t\"type\": 1\n\t},\n\t\"api_key\": \"{{token}}\"\n}\n",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{webhook_url}}",
              "host": [
                "{{webhook_url}}"
              ]
            },
            "description": "Provide parameter `senderid` instead of `to` where applicable.\n\n`\"type\": 1` - text message\n\n`\"type\": 2` - file"
          },
          "response": []
        },
